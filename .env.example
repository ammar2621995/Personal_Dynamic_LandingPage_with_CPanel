# ──────────────────────────────────────────────
#  BA Portfolio — Environment Variables TEMPLATE
#  Copy this file to .env and fill in your values
#  $ cp .env.example .env
# ──────────────────────────────────────────────

# Flask secret key — CHANGE THIS in production!
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-secret-key-here

# Database connection URI
# PostgreSQL: postgresql://username:password@localhost:5432/db_name
# SQLite: sqlite:///portfolio.db
DATABASE_URL=postgresql://username:password@localhost:5432/db_name

# Default admin password (first-time setup only)
ADMIN_DEFAULT_PASSWORD=change-me-immediately

# File upload directories (relative to app root)
UPLOAD_FOLDER=static/uploads
ATTACHMENTS_FOLDER=static/attachments

# Flask environment: development | production
FLASK_ENV=development

# Enable debug mode in development only
FLASK_DEBUG=True
